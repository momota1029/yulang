use std::core::ops::*
use std::data::opt::*

pub role Fold 'container:
    type item
    pub container.fold: 'acc -> ('acc -> ['e] item -> ['e] 'acc) -> ['e] 'acc
    pub container.find: (item -> ['e] bool) -> ['e] opt item = \f -> std::sub::sub:
        my nil = std::data::opt::opt::nil
        container.fold nil: \_ x -> if f x { std::sub::return:std::data::opt::opt::just x } else { nil }
    pub container.contains: item -> bool = \target ->
        my found = container.find: \x -> x == target
        case found:
            opt::nil -> false
            opt::just _ -> true
    pub container.each: [std::control::nondet::nondet] item = std::control::nondet::each container
