use std::text::yumark::*

my canary_document(format, algebra) =
    cons(
        text("cache"),
        cons(
            strong(cons(text(" boundary"), nil)),
            nil,
        ),
        format,
        algebra,
    )

pub cache_equivalence_render(): str =
    html_tag (render_html_doc canary_document)

cache_equivalence_render()
