my file_meta = catch (std::io::file::meta (std::text::path::of_bytes (std::text::str::to_bytes "/mock-file"))):
    std::io::file::file::meta path, k ->
        k (std::io::file::file_meta {
            kind: std::io::file::file_kind::file,
            size: 5,
            readonly: false,
            modified: std::data::opt::opt::nil,
        })
    value -> value

file_meta.kind
