use std::control::var::*

my body(text0) =
    my final = text0 + "!"
    ((text0, final), final)

my direct = body "start"

my run(backing, x: [_] _) = catch x:
    std::io::file::file::load path, k -> run backing: k (result::ok backing)
    std::io::file::file::store (path, text), k -> run text: k (result::ok ())
    value -> (value, backing)

(run "start": std::io::file::text_with (std::text::path::of_bytes (std::text::str::to_bytes "/mock")) body, direct)
