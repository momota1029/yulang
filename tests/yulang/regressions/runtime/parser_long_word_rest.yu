use std::data::result::*
use std::text::parse::*

my x10(s: str): str =
    s + s + s + s + s + s + s + s + s + s

my word_len(source: str): (int, int) = case read_prefix(source, word):
    result::ok found -> (found.value.len, found.rest.len)
    result::err _ -> (-1, -1)

my rest_len(source: str): (int, int) = case read_prefix(source, rest):
    result::ok found -> (found.value.len, found.rest.len)
    result::err _ -> (-1, -1)

my token_pos(source: str): ((int, int), int) = case read_prefix(source, \() -> {
    token("a👨‍👩‍👧‍👦b")()
    my pos = parse::pos()
    pos
}):
    result::ok found -> (found.value, found.rest.len)
    result::err _ -> ((-1, -1), -1)

my a10 = "aaaaaaaaaa"
my a100 = x10 a10
my a1000 = x10 a100
my a10000 = x10 a1000
my a22000 = a10000 + a10000 + a1000 + a1000

(
    word_len "",
    word_len "abc!",
    word_len "αβγ!",
    token_pos "a👨‍👩‍👧‍👦b!",
    word_len a22000,
    rest_len a22000
)
