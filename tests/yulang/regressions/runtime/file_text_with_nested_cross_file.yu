use std::control::var::*

my path_eq(a, b): bool =
    std::text::bytes::eq (std::text::path::to_bytes a) (std::text::path::to_bytes (std::text::path::of_bytes (std::text::str::to_bytes b)))

my edit() = std::io::file::text_with (std::text::path::of_bytes (std::text::str::to_bytes "/a")): \a0 ->
    my inner = std::io::file::text_with (std::text::path::of_bytes (std::text::str::to_bytes "/b")): \b0 ->
        my b1 = b0 + " b"
        my a1 = a0 + " a"
        ((b0, b1, a1), b1)
    ((a0, inner, a0 + " a"), a0 + " a")

my run(a, b, x: [_] _) = catch x:
    std::io::file::file::load path, k ->
        if path_eq path "/a":
            run a b: k (result::ok a)
        else:
            run a b: k (result::ok b)
    std::io::file::file::store (path, text), k ->
        if path_eq path "/a":
            run text b: k (result::ok ())
        else:
            run a text: k (result::ok ())
    value -> (value, a, b)

run "A" "B": edit()
