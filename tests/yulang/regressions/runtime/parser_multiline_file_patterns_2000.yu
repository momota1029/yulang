use std::text::parse::*

my x5(s: str): str =
    s + s + s + s + s

my x10(s: str): str =
    s + s + s + s + s + s + s + s + s + s

my zero: (int, int, int, int) = (0, 0, 0, 0)

my parse_ms_tail(tail: str): opt int =
    case tail.split_once " ms":
        just (ms, _) -> ms.trim.to_int
        nil -> nil

my classify_get(rest: str): (int, int, int, int) =
    case rest.split_once " took ":
        just (_, tail) -> case parse_ms_tail tail:
            just ms -> (1, 0, 0, ms)
            nil -> zero
        nil -> zero

my classify_warn(id: str, ms: str): (int, int, int, int) =
    case (id.to_int, ms.to_int):
        (just id_value, just ms_value) -> (0, 1, 0, id_value + ms_value)
        _ -> zero

my classify_port(key: str, value: str): (int, int, int, int) =
    if key.trim == "port":
        case value.trim.to_int:
            just port -> (0, 0, 1, port)
            nil -> zero
    else:
        zero

my classify(line: str): (int, int, int, int) = case line:
    ~"GET {rest = ..}" if rest.starts_with "/api" -> classify_get rest
    ~"WARN id=:id took :ms ms" -> classify_warn id ms
    ~":key = :value" -> classify_port key value
    _ -> zero

my add_sample(stats: (int, int, int, int), line: str): (int, int, int, int) =
    case (stats, classify line):
        ((api, warn, ports, total), (next_api, next_warn, next_ports, amount)) ->
            (api + next_api, warn + next_warn, ports + next_ports, total + amount)

my block =
    "GET /api/users took 15 ms\n"
        + "GET /static/app.js took 3 ms\n"
        + "WARN id=42 took 7 ms\n"
        + "port = 8080\n"

my path = {{file}}

my run() = {
    std::io::file::write_text path (x5 (x10 (x10 block)))
    ((std::io::file::read_text path).split "\n").fold zero add_sample
}

run()
