use std::control::nondet::*
use std::control::var::*
use std::text::str::*

my path = "/tmp/yulang-contract-unsupported-file-ref-lines-each-update-chain"

my &doc = std::io::file::text path

my touched = ((&doc.lines.each).update \line ->
    line.replace_once "todo:" "done:"
).list

("touched", touched, "after", $doc).say
