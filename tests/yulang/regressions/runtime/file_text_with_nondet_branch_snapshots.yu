use std::control::nondet::*

my result = (std::io::file::text_with __YULANG_FILE_TEXT_WITH_NONDET_PATH__: \&text ->
    my suffix = each [" A", " B"]
    my before = $text
    &text = before + suffix
    (suffix, $text)
).list
my after = std::io::file::read_text __YULANG_FILE_TEXT_WITH_NONDET_PATH__

(result, after)
