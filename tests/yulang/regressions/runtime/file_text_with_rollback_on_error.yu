pub error edit_err:
    abort

my before = std::io::file::read_text __YULANG_FILE_TEXT_WITH_ROLLBACK_PATH__
my wrapped = edit_err::wrap:
    std::io::file::text_with __YULANG_FILE_TEXT_WITH_ROLLBACK_PATH__: \&text ->
        my old = $text
        &text = old + " dirty"
        edit_err::abort.throw
my after = std::io::file::read_text __YULANG_FILE_TEXT_WITH_ROLLBACK_PATH__

(before, wrapped, after)
