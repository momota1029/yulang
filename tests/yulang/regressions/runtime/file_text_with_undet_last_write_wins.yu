use std::control::nondet::*
use std::control::var::*

my edit() = (std::io::file::text_with (std::text::path::of_bytes (std::text::str::to_bytes "/mock")): \text0 ->
    my suffix = each [" A", " B"]
    my final = text0 + suffix
    ((suffix, final), final)
).list

my run(backing, x: [_] _) = catch x:
    std::io::file::file::load path, k -> run backing: k (result::ok backing)
    std::io::file::file::store (path, text), k -> run text: k (result::ok ())
    value -> (value, backing)

run "start": edit()
