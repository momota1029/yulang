use std::control::var::*

my edit() = (\&text ->
    my before = $text
    &text = before + "!"
    (before, $text)
) (std::io::file::text "/mock")

my run(backing, x: [_] _) = catch x:
    std::io::file::file_buffer::ambient_get path, k -> run backing: k backing
    std::io::file::file_buffer::ambient_set (path, text), k -> run text: k ()
    value -> (value, backing)

run "start": edit()
